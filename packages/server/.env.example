DATABASE_URL="file:../data/oil-search.db"
PORT=3000

# admin API（/api/admin/*）目前沒有登入驗證。部署純前台版本時務必設為 "false"，
# 讓這個 server 不掛載 admin 路由；本機開發／審核資料時留空或設 "true" 即可。
ENABLE_ADMIN_API=true

# repo root，供 spawn python 腳本時當作 cwd（本機開發時通常是 ../..）
REPO_ROOT="../.."

# 每小時輪詢的來源頁面
FDA_DOWNSTREAM_AND_OILS_URL="https://www.fda.gov.tw/tc/siteList.aspx?sid=13708"
FDA_RECALL_LIST_URL="https://www.fda.gov.tw/tc/site.aspx?sid=13707"

DISCORD_WEBHOOK_URL=""
